

int getSign_Noncompliant(int x) // Noncompliant 
{
    if (x > 0) {
        return 1;
    } else if (x < 0) {
        return -1;
    }
    
}

int checkSwitch_Noncompliant(int x) // Noncompliant 
{
    switch (x) {
        case 1:
            return 10;
        case 2:
            return 20;
        // Missing default case
    }
}

int missingReturnAtEnd(int x) // Noncompliant 
{
    int y = x + 1;
    if (y > 10) {
        return y;
    }
   
}



void voidFunction(int x) 
{
    if (x > 0) return;
    // OK
}
int getSign_Compliant(int x)
{
    if (x > 0) {
        return 1;
    } else if (x < 0) {
        return -1;
    }
    return 0; // OK
}

int checkSwitch_Compliant(int x)
{
    switch (x) {
        case 1:
            return 10;
        default:
            return 0; // OK
    }
}

int simpleReturn(int x) {
    return x * 2; // OK
}

