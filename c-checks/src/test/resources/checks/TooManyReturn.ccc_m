int foo() {         // Noncompliant
  if (condition1) {
    return 1;
  } else {
    if (condition2) {
      return 0;
    } else {
      return 1;
    }
  }
  return 0;
}

int myFunction() {        // OK
  if (condition1) {
    return 1;
  } else if (condition2) {
      return 0;
  }
  return 0;
}

void nested_test() {     // OK

  int nested() {
    return 1;
  }

  if (condition1) {
    return 0;
  }
  return 0;
}